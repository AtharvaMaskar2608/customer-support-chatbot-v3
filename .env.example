# Copy to .env and fill in real values. Never commit .env (it is gitignored).

# --- Database (required) ---
# Single connection source for Postgres (pgvector installed, qa_chunks populated).
DATABASE_URL=postgresql://user:password@localhost:5432/customer-support-chatbot

# --- Anthropic / agent (required) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Pinned model id; thinking is always disabled by callers.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional: per-message output cap (default 1024).
ANTHROPIC_MAX_TOKENS=1024

# --- OpenAI / embeddings + default eval judge (required) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: embedding model + dim (defaults: text-embedding-3-large, 3072).
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# --- Confident AI / DeepEval (optional; enables eval export) ---
CONFIDENT_API_KEY=

# --- FinX Reports API (optional; default shown) ---
FINX_BASE_URL=https://finx.choiceindia.com

# --- Cost accounting (optional fallback) ---
# The USD -> INR rate is fetched live from https://open.er-api.com/v6/latest/USD
# once per process. This value is only used as a fallback when that fetch fails
# (offline/CI). If unset and the live fetch fails, settings loading raises.
USD_TO_INR=83.0
